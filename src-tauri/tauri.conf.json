{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pingu Music",
  "version": "0.1.22",
  "identifier": "com.pingu.music",
  "build": {
    "beforeDevCommand": "node scripts/tauri-dev-server.mjs",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Pingu Music",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
